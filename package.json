{
  "name": "@flyingsquirrel0419/zenv",
  "version": "0.1.1",
  "description": "Validate environment variables with Zod and human-friendly runtime errors.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyingsquirrel0419/zenv.git"
  },
  "homepage": "https://github.com/flyingsquirrel0419/zenv#readme",
  "bugs": {
    "url": "https://github.com/flyingsquirrel0419/zenv/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zenv": "bin/zenv.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.js",
      "require": "./dist/adapters/node.cjs"
    },
    "./nextjs": {
      "types": "./dist/adapters/nextjs.d.ts",
      "import": "./dist/adapters/nextjs.js",
      "require": "./dist/adapters/nextjs.cjs"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "import": "./dist/adapters/vite.js",
      "require": "./dist/adapters/vite.cjs"
    },
    "./nestjs": {
      "types": "./dist/adapters/nestjs.d.ts",
      "import": "./dist/adapters/nestjs.js",
      "require": "./dist/adapters/nestjs.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf coverage dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^4.0.0"
  }
}
